{
  "name": "solo-harness-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal intelligence harness — backend service governing a Claude worker",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:tsx": "tsx src/index.ts",
    "brief": "tsx src/scripts/run-brief.ts",
    "google-auth": "tsx src/scripts/google-auth.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@fastify/cors": "^10.0.1",
    "better-sqlite3": "^11.8.0",
    "exa-js": "^1.5.13",
    "fastify": "^5.2.1",
    "google-auth-library": "^9.15.1",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
