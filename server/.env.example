# Claude — subscription auth (Pro plan). Mint with: claude setup-token
# The Agent SDK reads this; no API credits used.
CLAUDE_CODE_OAUTH_TOKEN=

# Model defaults (Sonnet stretches the Pro quota; flip heavy tasks to Opus)
HARNESS_MODEL=claude-sonnet-4-6
HARNESS_MODEL_HEAVY=claude-opus-4-8

# Exa (news/search). Free tier ~$10 credits.
EXA_API_KEY=

# Server
PORT=8787
FRONTEND_ORIGIN=http://localhost:3000

# iMessage (macOS, read-only). Default path shown.
IMESSAGE_DB_PATH=/Users/me/Library/Messages/chat.db

# Google (Gmail + Calendar, read-only) — see GOOGLE_SETUP.md, then `npm run google-auth`
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_PORT=8788
APIFY_TOKEN=
